# JUST COPY THIS FILE AND CREATE NEW FILE NAME .ENV

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# JWT Configuration
JWT_SECRET=superSecretKey1234!
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100  # requests per window

# Logging
LOG_LEVEL=debug  # debug, info, warn, error

# Google OAuth
JWT_SECRET=superSecretKey1234!
GOOGLE_CLIENT_ID=100000000000000000000
GOOGLE_CLIENT_SECRET=100000000000000000000
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/gAuth/google/callback